    <!-- groovy -->
    <profile>
      <id>docs-groovy</id>
      <activation>
        <activeByDefault>false</activeByDefault>
        <property>
          <name>docs-groovy</name>
          <value>true</value>
        </property>
      </activation>
      <build>
        <plugins>
          <plugin>
            <groupId>org.asciidoctor</groupId>
            <artifactId>asciidoctor-maven-plugin</artifactId>
            <configuration>
              <attributes>
                <product.version>${project.version}</product.version>
                <productVersion>${project.version}</productVersion>
                <productReleaseDate>${maven.build.timestamp}</productReleaseDate>
              </attributes>
              <sourceDirectory>${basedir}/src/adoc/groovy</sourceDirectory>
              <sourceDocumentName>dossier-groovy.adoc</sourceDocumentName>
              <outputDirectory>${basedir}/src/main/resources/docs/groovy</outputDirectory>
            </configuration>
            <executions>
              <execution>
                <id>generate-pdf-groovy</id>
                <phase>generate-resources</phase>
                <goals>
                  <goal>process-asciidoc</goal>
                </goals>
                <configuration>
                  <skip>true</skip>
                  <sourceHighlighter>rouge</sourceHighlighter>
                  <backend>pdf</backend>
                </configuration>
              </execution>
              <execution>
                <id>generate-html5-groovy</id>
                <phase>generate-resources</phase>
                <goals>
                  <goal>process-asciidoc</goal>
                </goals>
                <configuration>
                  <skip>true</skip>
                  <backend>html5</backend>
                  <embedAssets>true</embedAssets>
                  <attributes>
                    <stylesheet>css/digitech.css</stylesheet>
                    <toc>left</toc>
                  </attributes>
                </configuration>
              </execution>
              <execution>
                <id>generate-slides-groovy</id>
                <phase>generate-resources</phase>
                <goals>
                  <goal>process-asciidoc</goal>
                </goals>
                <configuration>
                  <backend>revealjs</backend>
                  <sourceHighlighter>rouge</sourceHighlighter>
<!--                  <backend>revealjs</backend>-->
<!--                  <embedAssets>true</embedAssets>-->
<!--                  <attributes>-->
<!--                    <stylesheet>css/digitech.css</stylesheet>-->
<!--                    <toc>left</toc>-->
<!--                  </attributes>-->
<!--                  &lt;!&ndash; include the asciidoctor-revealjs gem &ndash;&gt;-->
<!--                  <gemPath>${project.build.directory}/gems</gemPath>-->
<!--                  <requires>-->
<!--                    <require>asciidoctor-revealjs</require>-->
<!--                  </requires>-->
<!--                  <outputDirectory>${project.slides.directory}</outputDirectory>-->
<!--                  <backend>revealjs</backend>-->
<!--                  <sourceHighlighter>rouge</sourceHighlighter>-->
                  <attributes>
                    <!--
                        As we are downloading reveal.js in runtime, it sits in a nonstandard folder `reveal.js-${revealjs.version}`
                    -->
<!--                    <revealjsdir>${basedir}/src/main/resources/docs/groovy</revealjsdir>-->
                    <revealjsdir>reveal.js-${revealjs.version}</revealjsdir>
                    <!-- put here the reveal.js specific attributes -->
<!--                    <revealjs_theme>black</revealjs_theme>-->
                    <revealjs_transition>linear</revealjs_transition>
                    <project-version>${project.version}</project-version>
                    <!-- can use any pygments/rouge css here -->
                    <rouge-css>class</rouge-css>
<!--                    <customcss>styles/monokai.css</customcss>-->
                  </attributes>
                </configuration>
              </execution>
            </executions>
          </plugin>
        </plugins>
      </build>
    </profile>

    <!-- sample officiel -->
    <profile>
      <id>docs-sample</id>
      <activation>
        <activeByDefault>false</activeByDefault>
        <property>
          <name>docs-sample</name>
          <value>true</value>
        </property>
      </activation>
      <build>
        <plugins>
          <plugin>
            <groupId>org.asciidoctor</groupId>
            <artifactId>asciidoctor-maven-plugin</artifactId>
            <executions>
              <execution>
                <id>generate-pdf-asciidoc-sample</id>
                <phase>generate-resources</phase>
                <goals>
                  <goal>process-asciidoc</goal>
                </goals>
                <configuration>
                  <attributes>
                    <pdf-stylesdir>${project.basedir}/src/adoc/z-asciidoc-sample</pdf-stylesdir>
                    <pdf-style>chronicles</pdf-style>
                  </attributes>
                  <sourceDirectory>${basedir}/src/adoc/z-asciidoc-sample</sourceDirectory>
                  <sourceDocumentName>chronicles-example.adoc</sourceDocumentName>
                  <outputDirectory>${basedir}/src/main/resources/docs/sample</outputDirectory>
                  <backend>pdf</backend>
                  <sourceHighlighter>coderay</sourceHighlighter>
                </configuration>
              </execution>
            </executions>
          </plugin>
        </plugins>
      </build>
    </profile>
  </profiles>

  <properties>
    <slides.directory>${project.build.directory}/generated-slides</slides.directory>
  </properties>

</project>