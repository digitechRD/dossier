<?xml version="1.0" encoding="UTF-8"?>
<project xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns="http://maven.apache.org/POM/4.0.0"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/maven-v4_0_0.xsd">
  <parent>
    <groupId>fr.digitech.ged.dossier</groupId>
    <artifactId>dossier.gh</artifactId>
    <version>1.0.1-SNAPSHOT</version>
  </parent>
  <modelVersion>4.0.0</modelVersion>
  <artifactId>dossier-docs</artifactId>
  <packaging>jar</packaging>
  <name>Dossier Docs</name>
  <version>1.0.1-SNAPSHOT</version>
  <description>Dossier asciidoc documentation</description>

  <profiles>
    <!-- sso -->
    <profile>
      <id>docs-sso</id>
      <activation>
        <activeByDefault>false</activeByDefault>
        <property>
          <name>docs-sso</name>
          <value>true</value>
        </property>
      </activation>
      <build>
        <plugins>
          <plugin>
            <groupId>org.asciidoctor</groupId>
            <artifactId>asciidoctor-maven-plugin</artifactId>
            <configuration>
              <attributes>
                <!--                    <pdf-stylesdir>${project.basedir}/src/adoc/administration</pdf-stylesdir>&ndash;&gt;-->
                <!--                    <pdf-style>digitech</pdf-style>-->
                <product.version>${project.version}</product.version>
                <productVersion>${project.version}</productVersion>
                <productReleaseDate>${maven.build.timestamp}</productReleaseDate>
              </attributes>
              <sourceDirectory>${basedir}/src/adoc/administration</sourceDirectory>
              <sourceDocumentName>installation-sso.adoc</sourceDocumentName>
              <outputDirectory>${basedir}/src/main/resources/docs/administration</outputDirectory>
            </configuration>
            <executions>
              <execution>
                <id>generate-pdf-sso</id>
                <phase>generate-resources</phase>
                <goals>
                  <goal>process-asciidoc</goal>
                </goals>
                <configuration>
                  
                  <sourceHighlighter>rouge</sourceHighlighter>
                  <backend>pdf</backend>
                </configuration>
              </execution>
              <execution>
                <id>generate-html5-sso</id>
                <phase>generate-resources</phase>
                <goals>
                  <goal>process-asciidoc</goal>
                </goals>
                <configuration>
                  <backend>html5</backend>
                  <embedAssets>true</embedAssets>
                  <attributes>
                    <stylesheet>css/digitech.css</stylesheet>
                    <toc>left</toc>
                  </attributes>
                </configuration>
              </execution>
            </executions>
          </plugin>
        </plugins>
      </build>
    </profile>

    <!-- sample officiel -->
    <profile>
      <id>docs-sample</id>
      <activation>
        <activeByDefault>false</activeByDefault>
        <property>
          <name>docs-sample</name>
          <value>true</value>
        </property>
      </activation>
      <build>
        <plugins>
          <plugin>
            <groupId>org.asciidoctor</groupId>
            <artifactId>asciidoctor-maven-plugin</artifactId>
            <version>${asciidoctor-maven-plugin.version}</version>
            <dependencies>
              <!-- Comment this section to use the default jruby artifact provided by the plugin -->
              <dependency>
                <groupId>org.jruby</groupId>
                <artifactId>jruby-complete</artifactId>
                <version>${jruby-complete.version}</version>
              </dependency>
              <dependency>
                <groupId>org.asciidoctor</groupId>
                <artifactId>asciidoctorj-pdf</artifactId>
                <version>${asciidoctorj-pdf.version}</version>
              </dependency>
            </dependencies>
            <executions>
              <execution>
                <id>generate-pdf-asciidoc-sample</id>
                <phase>generate-resources</phase>
                <goals>
                  <goal>process-asciidoc</goal>
                </goals>
                <configuration>
                  <attributes>
                    <pdf-stylesdir>${project.basedir}/src/adoc/z-asciidoc-sample</pdf-stylesdir>
                    <pdf-style>chronicles</pdf-style>
                  </attributes>
                  <sourceDirectory>${basedir}/src/adoc/z-asciidoc-sample</sourceDirectory>
                  <sourceDocumentName>chronicles-example.adoc</sourceDocumentName>
                  <outputDirectory>${basedir}/src/main/resources/docs/sample</outputDirectory>
                  <backend>pdf</backend>
                  <sourceHighlighter>coderay</sourceHighlighter>
                </configuration>
              </execution>
            </executions>
          </plugin>
        </plugins>
      </build>
    </profile>

  </profiles>

</project>